# Basic Arithmetic Operations on Two Numbers
num1 = int(input("Enter the first number: "))
num2 = int(input("Enter the second number: "))
add = num1 + num2
sub = num1 - num2
mul = num1 * num2
div = num1 / num2
rem = num1 % num2
print("The Addition of two numbers is:", add)
print("The Subtraction of two numbers is:", sub)
print("The Product of two numbers is:", mul)
print("The Division of two numbers is:", round(div,2), "And the reminder is:",rem)
